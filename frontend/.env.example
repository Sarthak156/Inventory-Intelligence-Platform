# Backend API base URL for the inventory intelligence platform.
# Override this in production (Vercel, Render, Railway, etc.).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Browser key used by the optional Gemini enhancement layer.
# For production, proxy Gemini through a backend or edge function to keep credentials private.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash
