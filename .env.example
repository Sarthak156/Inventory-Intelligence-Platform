# =============================================================================
# Inventory Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION
# -----------------------------------------------------------------------------

# Frontend URL for CORS configuration
# In development: http://localhost:5173
# In production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------

# Backend API Base URL
# In development (with Vite proxy): Leave empty or http://127.0.0.1:8000
# In production: https://your-username-inventory-intelligence-api.hf.space
VITE_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# AI / GEMINI API CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Google Gemini API Key for enhanced AI insights
# Get your key at: https://aistudio.google.com/app/apikey
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# DEPLOYMENT CONFIGURATION (Vercel)
# -----------------------------------------------------------------------------

# Set these in Vercel Project Settings → Environment Variables
# VITE_API_BASE_URL=https://your-username-inventory-intelligence-api.hf.space

# -----------------------------------------------------------------------------
# DEPLOYMENT CONFIGURATION (HuggingFace Spaces)
# -----------------------------------------------------------------------------

# Set these in HF Space Settings → Repository Secrets
# FRONTEND_URL=https://your-frontend.vercel.app